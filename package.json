{
  "name": "harem-manager",
  "version": "1.0.0",
  "description": "Gerenciador de Waifus para RPG",
  "main": "main.js",
  "author": "Fullerboat",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac":   "electron-builder --mac",
    "build:all":   "electron-builder --win --linux --mac"
  },
  "build": {
    "appId": "com.fullerboat.waifus-rpg",
    "productName": "Waifus RPG",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "html/**",
      "css/**",
      "js/**",
      "img/**",
      "data/**"
    ],
    "win": {
      "target": "nsis"
      
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.0.0"
  }
}